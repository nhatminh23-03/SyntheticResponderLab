# Required in production-like environments.
API_BASE_URL=http://localhost:8000

# Required in production-like environments and must match the backend.
DEPLOYMENT_SHARED_SECRET=

# Optional. Legacy shared-password pre-gate.
# When Clerk is configured (below), APP_ACCESS_PASSWORD is NOT required. Leave empty for normal operation.
# Set it only if you need an emergency/maintenance extra gate in front of Clerk.
# If set in a production-like environment, it must be at least 12 characters.
APP_ACCESS_PASSWORD=

# Clerk (external auth). Required in production-like environments unless
# APP_ACCESS_PASSWORD is set as a standalone fallback gate.
# Obtain these from https://dashboard.clerk.com for your instance.
# Configure the Clerk instance in "Restricted" mode and disable public sign-ups;
# admins issue invitations from the Clerk dashboard.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional Clerk URL overrides. The defaults below match the app's routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Public-launch note:
# Clerk owns credential security and invite acceptance. Configure brute-force
# protection at the hosting edge (for /sign-in, /sign-up, Clerk callbacks, and
# /api/backend/*) rather than implementing local password throttling in-app.
